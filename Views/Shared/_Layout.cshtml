@using MemoLens.Models
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var isSignedIn = SignInManager.IsSignedIn(User);
    var currentUser = isSignedIn ? await UserManager.GetUserAsync(User) : null;
    var displayName = currentUser?.DisplayName ?? currentUser?.Email ?? User.Identity?.Name ?? "Tài khoản";
    var profileInitial = string.IsNullOrWhiteSpace(displayName) ? "M" : displayName.Substring(0, 1).ToUpperInvariant();
    string ActiveNav(string controller) => string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) ? "is-active" : "";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MemoLens</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MemoLens.styles.css" asp-append-version="true" />
</head>
<body class="memolens-shell">
    <header class="site-header">
        <nav class="navbar navbar-expand-lg memolens-navbar" aria-label="Điều hướng chính">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark" aria-hidden="true">M</span>
                    <span>MemoLens</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar"
                        aria-expanded="false" aria-label="Mở điều hướng">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div id="mainNavbar" class="navbar-collapse collapse">
                    <ul class="navbar-nav ms-auto align-items-lg-center">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Memories" asp-action="Index">Dòng thời gian</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Albums" asp-action="Index">Bộ sưu tập</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Trash" asp-action="Index">Thùng rác</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-soft" asp-area="" asp-controller="Memories" asp-action="Create">Tạo kỷ niệm</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Quyền riêng tư</a>
                        </li>
                        @if (isSignedIn)
                        {
                            <li class="nav-item nav-account">
                                <span class="navbar-text account-label">@displayName</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Settings" asp-action="Index">Cài đặt</a>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline nav-action-form">
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">Đăng xuất</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item nav-account">
                                <a class="nav-link" asp-area="" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-sm btn-primary nav-register-button" asp-area="" asp-controller="Account" asp-action="Register">Đăng ký</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="app-frame">
        <aside class="desktop-sidebar" aria-label="Điều hướng MemoLens">
            <a class="desktop-sidebar-brand" asp-controller="Home" asp-action="Index">
                <span>MemoLens</span>
            </a>
            <nav class="desktop-sidebar-nav">
                <a class="@ActiveNav("Memories")" asp-controller="Memories" asp-action="Index">
                    <span class="sidebar-mark" aria-hidden="true">T</span>
                    <span>Timeline</span>
                </a>
                <a asp-controller="Memories" asp-action="Create">
                    <span class="sidebar-mark" aria-hidden="true">M</span>
                    <span>Memories</span>
                </a>
                <a class="@ActiveNav("Albums")" asp-controller="Albums" asp-action="Index">
                    <span class="sidebar-mark" aria-hidden="true">A</span>
                    <span>Albums</span>
                </a>
                <a class="@ActiveNav("Trash")" asp-controller="Trash" asp-action="Index">
                    <span class="sidebar-mark" aria-hidden="true">R</span>
                    <span>Trash</span>
                </a>
                <a class="@ActiveNav("Settings")" asp-controller="Settings" asp-action="Index">
                    <span class="sidebar-mark" aria-hidden="true">S</span>
                    <span>Settings</span>
                </a>
            </nav>
            <div class="desktop-sidebar-foot">
                <span>Private journal</span>
                <small>Không feed, không like, không follower.</small>
            </div>
        </aside>

        <div class="container page-content">
            <main role="main" class="pb-4 app-main-paper">
                <div class="desktop-profile-row">
                    @if (isSignedIn)
                    {
                        <a class="profile-chip" asp-controller="Settings" asp-action="Index" aria-label="Mở cài đặt tài khoản">
                            <span aria-hidden="true">@profileInitial</span>
                        </a>
                    }
                    else
                    {
                        <a class="profile-chip" asp-controller="Account" asp-action="Login" aria-label="Đăng nhập">
                            <span aria-hidden="true">M</span>
                        </a>
                    }
                </div>
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="footer">
        <div class="container footer-inner">
            <div>
                <strong>MemoLens</strong>
                <span>Kỷ niệm riêng tư, chỉ thuộc về bạn.</span>
            </div>
            <a asp-controller="Home" asp-action="Privacy">Quyền riêng tư</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
