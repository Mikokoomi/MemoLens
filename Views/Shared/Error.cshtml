@model ErrorViewModel
@{
    ViewData["Title"] = "Lỗi";
}

<section class="content-panel status-panel">
    <p class="kicker">Có lỗi xảy ra</p>
    <h1>MemoLens chưa thể xử lý yêu cầu này.</h1>
    <p>Vui lòng thử lại sau hoặc quay lại trang trước đó.</p>

    @if (Model.ShowRequestId)
    {
        <p>
            <strong>Mã yêu cầu:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <div class="memory-filter-alert">
        <p>Trong môi trường phát triển, bạn có thể xem thêm chi tiết lỗi bằng cấu hình <strong>Development</strong>.</p>
        <p>Không bật chế độ này khi triển khai thật vì có thể làm lộ thông tin nhạy cảm.</p>
    </div>
</section>
