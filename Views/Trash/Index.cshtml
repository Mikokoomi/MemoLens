@model MemoLens.Models.Trash.TrashIndexViewModel

@{
    ViewData["Title"] = "Thùng rác";
}

<section class="memory-page-header">
    <div>
        <p class="kicker">Khôi phục riêng tư</p>
        <h1>Thùng rác</h1>
        <p>Các kỷ niệm và bộ sưu tập đã xóa sẽ xuất hiện tại đây để bạn có thể khôi phục khi cần.</p>
    </div>
    <div class="memory-action-row">
        <a class="btn btn-outline-secondary" asp-controller="Memories" asp-action="Index">Dòng thời gian</a>
        <a class="btn btn-outline-secondary" asp-controller="Albums" asp-action="Index">Bộ sưu tập</a>
    </div>
</section>

@if (TempData["TrashMessage"] is string message)
{
    <div class="trash-message" role="status">@message</div>
}

@if (Model.IsEmpty)
{
    <section class="memory-empty-state">
        <p class="kicker">Đang trống</p>
        <h2>Thùng rác đang trống.</h2>
        <p>Những gì bạn xóa sẽ xuất hiện ở đây để có thể khôi phục. MemoLens chưa xóa vĩnh viễn trong giai đoạn này.</p>
    </section>
}
else
{
    <section class="trash-section" aria-labelledby="deleted-memories-title">
        <div class="trash-section-heading">
            <p class="kicker">Kỷ niệm đã xóa</p>
            <h2 id="deleted-memories-title">Kỷ niệm đã xóa</h2>
        </div>

        @if (!Model.DeletedMemories.Any())
        {
            <div class="trash-empty-note">Không có kỷ niệm nào trong thùng rác.</div>
        }
        else
        {
            <div class="trash-grid">
                @foreach (var memory in Model.DeletedMemories)
                {
                    <article class="trash-card">
                        <div class="trash-card-placeholder">
                            <span>Không hiển thị ảnh trong thùng rác</span>
                        </div>
                        <div class="trash-card-body">
                            <div class="trash-meta">
                                <span>@memory.Feeling</span>
                                <span>@memory.MemoryDate.ToString("dd/MM/yyyy")</span>
                            </div>
                            <h3>@memory.Title</h3>
                            @if (!string.IsNullOrWhiteSpace(memory.Location))
                            {
                                <p class="memory-location">@memory.Location</p>
                            }
                            <p class="memory-preview-text">
                                @(string.IsNullOrWhiteSpace(memory.Story)
                                    ? "Chưa có câu chuyện cho kỷ niệm này."
                                    : memory.Story.Length > 150 ? $"{memory.Story[..150]}..." : memory.Story)
                            </p>
                            <p class="trash-deleted-at">Đã xóa: @(memory.DeletedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "Không rõ thời gian")</p>
                            <form asp-action="RestoreMemory" asp-route-id="@memory.Id" method="post">
                                <button type="submit" class="btn btn-primary w-100">Khôi phục kỷ niệm</button>
                            </form>
                        </div>
                    </article>
                }
            </div>
        }
    </section>

    <section class="trash-section" aria-labelledby="deleted-albums-title">
        <div class="trash-section-heading">
            <p class="kicker">Bộ sưu tập đã xóa</p>
            <h2 id="deleted-albums-title">Bộ sưu tập đã xóa</h2>
        </div>

        @if (!Model.DeletedAlbums.Any())
        {
            <div class="trash-empty-note">Không có bộ sưu tập nào trong thùng rác.</div>
        }
        else
        {
            <div class="trash-grid">
                @foreach (var album in Model.DeletedAlbums)
                {
                    <article class="trash-card">
                        <div class="trash-card-placeholder">
                            <span>Bộ sưu tập riêng tư</span>
                        </div>
                        <div class="trash-card-body">
                            <h3>@album.Title</h3>
                            <p class="memory-preview-text">
                                @(string.IsNullOrWhiteSpace(album.Description)
                                    ? "Chưa có mô tả cho bộ sưu tập này."
                                    : album.Description.Length > 180 ? $"{album.Description[..180]}..." : album.Description)
                            </p>
                            <p class="trash-deleted-at">Đã xóa: @(album.DeletedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "Không rõ thời gian")</p>
                            <form asp-action="RestoreAlbum" asp-route-id="@album.Id" method="post">
                                <button type="submit" class="btn btn-primary w-100">Khôi phục bộ sưu tập</button>
                            </form>
                        </div>
                    </article>
                }
            </div>
        }
    </section>
}
