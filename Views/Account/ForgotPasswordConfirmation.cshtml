@{
    ViewData["Title"] = "Kiểm tra email";
}

@inject IWebHostEnvironment HostEnvironment

<section class="auth-status-shell">
    <div class="status-card">
        <p class="kicker">Yêu cầu đã được tiếp nhận</p>
        <h1>Kiểm tra hướng dẫn đặt lại mật khẩu.</h1>
        <p>
            Nếu email tồn tại trong hệ thống và đã được xác thực, MemoLens sẽ gửi hướng dẫn đặt lại mật khẩu.
        </p>
        @if (HostEnvironment.IsDevelopment())
        {
            <div class="trust-note development-note">
                <strong>Môi trường Development:</strong>
                <span>Kiểm tra terminal/console để lấy link đặt lại mật khẩu. Giao diện không hiển thị token thô.</span>
            </div>
        }
        <a class="btn btn-outline-secondary" asp-action="Login">Quay lại đăng nhập</a>
    </div>
</section>
