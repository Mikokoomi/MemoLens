@model bool

@{
    ViewData["Title"] = "Email confirmation";
}

<section class="content-panel">
    @if (Model)
    {
        <p class="eyebrow">Confirmed</p>
        <h1 class="fw-semibold">Your email is confirmed.</h1>
        <p class="lead text-muted">You can now log in and open your private MemoLens timeline.</p>
        <a class="btn btn-primary" asp-action="Login">Login</a>
    }
    else
    {
        <p class="eyebrow">Confirmation failed</p>
        <h1 class="fw-semibold">We could not confirm this email link.</h1>
        <p class="lead text-muted">The link may be missing, expired, or already used. Register again or ask for a new confirmation flow later.</p>
        <a class="btn btn-outline-secondary" asp-action="Register">Back to Register</a>
    }
</section>
