@{
    ViewData["Title"] = "Kiểm tra link xác thực";
    var email = ViewData["Email"] as string;
}

@inject IWebHostEnvironment HostEnvironment

<section class="content-panel status-panel">
    <p class="kicker">Gần hoàn tất</p>
    <h1>Xác thực email trước khi đăng nhập.</h1>
    <p>
        Chúng tôi đã gửi hướng dẫn xác thực cho @(email ?? "tài khoản của bạn").
        Hãy xác thực email trước khi quay lại đăng nhập.
    </p>
    @if (HostEnvironment.IsDevelopment())
    {
        <p class="mb-4">
            <strong>Môi trường Development:</strong> kiểm tra terminal/console để lấy link xác nhận email.
        </p>
    }
    <a class="btn btn-outline-secondary" asp-action="Login">Đi tới đăng nhập</a>
</section>
