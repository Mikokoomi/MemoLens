@{
    ViewData["Title"] = "Kiểm tra link xác thực";
    var email = ViewData["Email"] as string;
}

@inject IWebHostEnvironment HostEnvironment

<section class="auth-status-shell">
    <div class="status-card">
        <p class="kicker">Gần hoàn tất</p>
        <h1>Xác thực email trước khi đăng nhập.</h1>
        <p>
            MemoLens đã gửi hướng dẫn xác thực cho @(email ?? "tài khoản của bạn").
            Sau khi xác thực, bạn có thể đăng nhập và bắt đầu lưu ký ức riêng tư.
        </p>
        @if (HostEnvironment.IsDevelopment())
        {
            <div class="trust-note development-note">
                <strong>Môi trường Development:</strong>
                <span>Kiểm tra terminal/console để lấy link xác nhận email. MemoLens không hiển thị token thô trong giao diện.</span>
            </div>
        }
        <a class="btn btn-primary" asp-action="Login">Đi tới đăng nhập</a>
    </div>
</section>
