@model MemoLens.Models.Account.ResetPasswordViewModel

@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<section class="auth-shell compact">
    <div class="auth-intro">
        <p class="kicker">Bảo vệ tài khoản</p>
        <h1>Tạo mật khẩu mới cho không gian MemoLens của bạn.</h1>
        <p>
            Sau khi đặt lại mật khẩu, bạn cần đăng nhập lại. Các refresh token API đang hoạt động sẽ được thu hồi.
        </p>
        <div class="trust-note">
            <strong>Mật khẩu mới.</strong>
            <span>Dùng tối thiểu 8 ký tự, có chữ và số để phù hợp với quy tắc Identity hiện tại.</span>
        </div>
    </div>

    <div class="auth-card">
        <div class="auth-card-heading">
            <p class="kicker">Đặt lại mật khẩu</p>
            <h2>Cập nhật mật khẩu</h2>
        </div>

        <form asp-action="ResetPassword" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="text-danger validation-summary mb-3"></div>

            <input asp-for="Token" type="hidden" />

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" readonly autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100">Đặt lại mật khẩu</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
