@model MemoLens.Models.Account.RegisterViewModel

@{
    ViewData["Title"] = "Đăng ký";
}

<section class="auth-shell">
    <div class="auth-intro">
        <p class="kicker">Bắt đầu riêng tư</p>
        <h1>Tạo một nơi yên tĩnh cho ảnh và câu chuyện của bạn.</h1>
        <p>
            Tài khoản MemoLens giúp bạn lưu ký ức theo timeline và album cá nhân. Email cần được xác thực trước khi đăng nhập.
        </p>
        <div class="trust-note">
            <strong>Bạn sở hữu ký ức của mình.</strong>
            <span>Ảnh và câu chuyện được giữ riêng theo tài khoản trong MVP hiện tại.</span>
        </div>
    </div>

    <div class="auth-card">
        <div class="auth-card-heading">
            <p class="kicker">Đăng ký</p>
            <h2>Tạo tài khoản MemoLens</h2>
        </div>

        <form asp-action="Register" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="text-danger validation-summary mb-3"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DisplayName" class="form-label"></label>
                <input asp-for="DisplayName" class="form-control" autocomplete="name" />
                <span asp-validation-for="DisplayName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="Password" class="text-danger"></span>
                <div class="form-text">Ít nhất 8 ký tự, có chữ và số.</div>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100">Tạo tài khoản</button>
        </form>

        <p class="auth-switch">
            Đã có tài khoản?
            <a asp-action="Login">Đăng nhập</a>
        </p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
