@model IReadOnlyList<MemoLens.Models.Albums.AlbumListItemViewModel>

@{
    ViewData["Title"] = "Bộ sưu tập";
}

<section class="collection-hero paper-note-panel paper-shell">
    <div>
        <p class="kicker page-kicker">Bộ sưu tập riêng tư</p>
        <h1 class="page-title">Bộ sưu tập</h1>
        <p>Lưu giữ những khoảnh khắc theo chủ đề bạn yêu thích.</p>
    </div>
    <div class="collection-hero-actions">
        <span>@Model.Count bộ sưu tập</span>
        <a class="btn btn-primary" asp-action="Create">+ Tạo bộ sưu tập</a>
    </div>
</section>

@if (!Model.Any())
{
    <section class="memory-empty-state collection-empty-state">
        <p class="kicker">Chưa có bộ sưu tập</p>
        <h2>Bắt đầu bằng một chủ đề nhỏ.</h2>
        <p>Tạo bộ sưu tập cho một chuyến đi, một năm học, gia đình, bạn bè hoặc bất kỳ khoảng thời gian nào bạn muốn nhìn lại như một câu chuyện riêng.</p>
        <a class="btn btn-primary" asp-action="Create">Tạo bộ sưu tập đầu tiên</a>
    </section>
}
else
{
    <section class="album-grid collection-grid" aria-label="Danh sách bộ sưu tập">
        @foreach (var album in Model)
        {
            <article class="album-card collection-card photo-note-card tape">
                <a class="album-cover collection-cover photo-note-cover" asp-action="Details" asp-route-id="@album.Id" aria-label="Mở bộ sưu tập @album.Title">
                    @if (!album.CoverImageId.HasValue)
                    {
                        <span>Chưa có ảnh bìa</span>
                    }
                    else
                    {
                        <img src="@Url.Action("MemoryImage", "Images", new { id = album.CoverImageId })" alt="Ảnh bìa của bộ sưu tập @album.Title" onerror="this.hidden=true; this.parentElement.classList.add('image-missing');" />
                    }
                </a>
                <div class="album-card-body collection-card-body">
                    <div class="album-card-meta collection-meta">
                        <span>@album.MemoryCount kỷ niệm</span>
                        <span>Cập nhật @album.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy")</span>
                    </div>
                    <h2><a asp-action="Details" asp-route-id="@album.Id">@album.Title</a></h2>
                    <p>@(string.IsNullOrWhiteSpace(album.Description) ? "Chưa có mô tả." : album.Description)</p>
                    <div class="album-card-actions collection-actions">
                        <a class="btn btn-primary" asp-action="Details" asp-route-id="@album.Id">Mở</a>
                        <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@album.Id">Sửa</a>
                    </div>
                </div>
            </article>
        }
    </section>
}
