@model MemoLens.Models.Albums.AlbumFormViewModel

@{
    ViewData["Title"] = "Sua bo suu tap";
}

<section class="memory-form-shell">
    <div class="memory-form-intro">
        <p class="kicker">Sua bo suu tap</p>
        <h1>Cap nhat ten va mo ta, giu nguyen quyen rieng tu.</h1>
        <p>Chinh sua nay chi doi thong tin bo suu tap. Cac ky niem goc va anh khong bi thay doi.</p>
    </div>

    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="memory-form-panel">
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger validation-summary mb-3"></div>

        <div class="mb-3">
            <label asp-for="Title" class="form-label">Ten bo suu tap</label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Description" class="form-label">Mo ta</label>
            <textarea asp-for="Description" class="form-control" rows="5"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
            <div class="form-text">Mo ta giup ban nho vi sao nhung ky niem nay nam cung nhau.</div>
        </div>

        <div class="memory-action-row">
            <button type="submit" class="btn btn-primary">Luu thay doi</button>
            <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Huy</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
