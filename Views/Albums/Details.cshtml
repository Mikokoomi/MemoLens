@model MemoLens.Models.Albums.AlbumDetailsViewModel

@{
    ViewData["Title"] = Model.Title;
}

<section class="album-detail">
    <div class="memory-detail-main">
        <p class="kicker">Bo suu tap rieng tu</p>
        <h1>@Model.Title</h1>
        <p class="album-description">
            @(string.IsNullOrWhiteSpace(Model.Description) ? "Bo suu tap nay chua co mo ta. Ban co the sua de ghi lai ly do minh gom nhung ky niem nay." : Model.Description)
        </p>

        <dl class="memory-facts compact">
            <div>
                <dt>Ky niem</dt>
                <dd>@Model.Memories.Count</dd>
            </div>
            <div>
                <dt>Cap nhat</dt>
                <dd>@Model.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy")</dd>
            </div>
        </dl>

        <div class="memory-action-row">
            <a class="btn btn-primary" asp-action="AddMemories" asp-route-id="@Model.Id">Them ky niem</a>
            <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.Id">Sua bo suu tap</a>
            <a class="btn btn-outline-secondary" asp-action="Delete" asp-route-id="@Model.Id">Xoa bo suu tap</a>
            <a class="btn btn-link" asp-action="Index">Quay lai bo suu tap</a>
        </div>
    </div>

    <aside class="memory-side-panel">
        <p class="kicker">Anh bia tu dong</p>
        @if (string.IsNullOrWhiteSpace(Model.CoverImagePath))
        {
            <div class="memory-card-photo-placeholder large">
                <span>MemoLens se dung anh dau tien tu ky niem dau tien trong bo suu tap.</span>
            </div>
        }
        else
        {
            <figure class="album-cover-preview">
                <img src="@Model.CoverImagePath" alt="Anh bia cua bo suu tap @Model.Title" />
            </figure>
        }
    </aside>
</section>

@if (!Model.Memories.Any())
{
    <section class="memory-empty-state">
        <p class="kicker">Chua co ky niem</p>
        <h2>Bo suu tap nay dang cho nhung khoanh khac dau tien.</h2>
        <p>Them ky niem da co trong timeline cua ban. Thao tac nay khong tao ban sao va khong thay doi ky niem goc.</p>
        <a class="btn btn-primary" asp-action="AddMemories" asp-route-id="@Model.Id">Them ky niem</a>
    </section>
}
else
{
    <section class="memory-list album-memory-list" aria-label="Ky niem trong bo suu tap">
        @foreach (var memory in Model.Memories)
        {
            <article class="memory-card">
                @if (string.IsNullOrWhiteSpace(memory.CoverImagePath))
                {
                    <div class="memory-card-photo-placeholder">
                        <span>Chua co anh</span>
                    </div>
                }
                else
                {
                    <a class="memory-card-cover" asp-controller="Memories" asp-action="Details" asp-route-id="@memory.Id">
                        <img src="@memory.CoverImagePath" alt="@memory.Title" />
                    </a>
                }

                <div>
                    <div class="memory-card-meta">
                        <span>@memory.MemoryDate.ToString("dd/MM/yyyy")</span>
                        <span>@memory.Feeling</span>
                    </div>
                    <h2><a asp-controller="Memories" asp-action="Details" asp-route-id="@memory.Id">@memory.Title</a></h2>
                    <p class="memory-location">@(string.IsNullOrWhiteSpace(memory.Location) ? "Chua them dia diem" : memory.Location)</p>
                    <p class="memory-preview-text">
                        @(string.IsNullOrWhiteSpace(memory.Story) ? "Chua co cau chuyen cho ky niem nay." : memory.Story)
                    </p>
                    <form asp-action="RemoveMemory" asp-route-id="@Model.Id" asp-route-memoryId="@memory.Id" method="post" class="album-remove-form">
                        <button type="submit" class="btn btn-outline-secondary">Go khoi bo suu tap</button>
                    </form>
                </div>
            </article>
        }
    </section>
}
