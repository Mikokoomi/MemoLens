@model MemoLens.Models.Albums.AlbumDetailsViewModel

@{
    ViewData["Title"] = Model.Title;
}

<section class="album-detail">
    <div class="memory-detail-main">
        <p class="kicker">Bộ sưu tập riêng tư</p>
        <h1>@Model.Title</h1>
        <p class="album-description">
            @(string.IsNullOrWhiteSpace(Model.Description) ? "Bộ sưu tập này chưa có mô tả. Bạn có thể sửa để ghi lại lý do mình gom những kỷ niệm này." : Model.Description)
        </p>

        <dl class="memory-facts compact">
            <div>
                <dt>Kỷ niệm</dt>
                <dd>@Model.Memories.Count</dd>
            </div>
            <div>
                <dt>Cập nhật</dt>
                <dd>@Model.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy")</dd>
            </div>
        </dl>

        <div class="memory-action-row">
            <a class="btn btn-primary" asp-action="AddMemories" asp-route-id="@Model.Id">Thêm kỷ niệm</a>
            <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.Id">Sửa bộ sưu tập</a>
            <a class="btn btn-outline-secondary" asp-action="Delete" asp-route-id="@Model.Id">Xóa bộ sưu tập</a>
            <a class="btn btn-link" asp-action="Index">Quay lại bộ sưu tập</a>
        </div>
    </div>

    <aside class="memory-side-panel">
        <p class="kicker">Ảnh bìa tự động</p>
        @if (!Model.CoverImageId.HasValue)
        {
            <div class="memory-card-photo-placeholder large">
                <span>MemoLens sẽ dùng ảnh đầu tiên từ kỷ niệm đầu tiên trong bộ sưu tập.</span>
            </div>
        }
        else
        {
            <figure class="album-cover-preview">
                <img src="@Url.Action("MemoryImage", "Images", new { id = Model.CoverImageId })" alt="Ảnh bìa của bộ sưu tập @Model.Title" onerror="this.hidden=true; this.parentElement.classList.add('image-missing');" />
            </figure>
        }
    </aside>
</section>

@if (!Model.Memories.Any())
{
    <section class="memory-empty-state">
        <p class="kicker">Chưa có kỷ niệm</p>
        <h2>Bộ sưu tập này đang chờ những khoảnh khắc đầu tiên.</h2>
        <p>Thêm kỷ niệm đã có trong dòng thời gian của bạn. Thao tác này không tạo bản sao và không thay đổi kỷ niệm gốc.</p>
        <a class="btn btn-primary" asp-action="AddMemories" asp-route-id="@Model.Id">Thêm kỷ niệm</a>
    </section>
}
else
{
    <section class="memory-list album-memory-list" aria-label="Kỷ niệm trong bộ sưu tập">
        @foreach (var memory in Model.Memories)
        {
            <article class="memory-card">
                @if (!memory.CoverImageId.HasValue)
                {
                    <div class="memory-card-photo-placeholder">
                        <span>Chưa có ảnh</span>
                    </div>
                }
                else
                {
                    <a class="memory-card-cover" asp-controller="Memories" asp-action="Details" asp-route-id="@memory.Id">
                        <img src="@Url.Action("MemoryImage", "Images", new { id = memory.CoverImageId })" alt="@memory.Title" onerror="this.hidden=true; this.parentElement.classList.add('image-missing');" />
                    </a>
                }

                <div>
                    <div class="memory-card-meta">
                        <span>@memory.MemoryDate.ToString("dd/MM/yyyy")</span>
                        <span>@memory.Feeling</span>
                    </div>
                    <h2><a asp-controller="Memories" asp-action="Details" asp-route-id="@memory.Id">@memory.Title</a></h2>
                    <p class="memory-location">@(string.IsNullOrWhiteSpace(memory.Location) ? "Chưa thêm địa điểm" : memory.Location)</p>
                    <p class="memory-preview-text">
                        @(string.IsNullOrWhiteSpace(memory.Story) ? "Chưa có câu chuyện cho kỷ niệm này." : memory.Story)
                    </p>
                    <form asp-action="RemoveMemory" asp-route-id="@Model.Id" asp-route-memoryId="@memory.Id" method="post" class="album-remove-form">
                        <button type="submit" class="btn btn-outline-secondary">Gỡ khỏi bộ sưu tập</button>
                    </form>
                </div>
            </article>
        }
    </section>
}
