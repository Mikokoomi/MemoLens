@model MemoLens.Models.Albums.AlbumFormViewModel

@{
    ViewData["Title"] = "Tạo bộ sưu tập";
}

<section class="memory-form-shell memory-writing-shell collection-form-shell">
    <aside class="memory-form-intro paper-note-panel">
        <p class="kicker">Tạo bộ sưu tập</p>
        <h1>Tạo bộ sưu tập</h1>
        <p>Tạo một bộ sưu tập mới để lưu giữ những khoảnh khắc đáng nhớ.</p>
        <div class="private-note">
            <strong>Riêng tư mặc định</strong>
            <span>Bộ sưu tập chỉ sắp xếp kỷ niệm trong tài khoản của bạn, không tạo bản sao hay chia sẻ công khai.</span>
        </div>
    </aside>

    <form asp-action="Create" method="post" class="memory-form-card collection-form-card">
        <div asp-validation-summary="ModelOnly" class="text-danger validation-summary form-validation-note mb-3"></div>

        <section class="form-section" aria-labelledby="album-create-heading">
            <div class="form-section-heading">
                <p class="kicker">Thông tin</p>
                <h2 id="album-create-heading">Tên bộ sưu tập</h2>
            </div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label">Tên bộ sưu tập</label>
                <input asp-for="Title" class="form-control" placeholder="Ví dụ: Mùa hè năm nay" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-0">
                <label asp-for="Description" class="form-label">Mô tả ngắn</label>
                <textarea asp-for="Description" class="form-control journal-textarea album-description-field" rows="5" placeholder="Viết vài dòng mô tả về bộ sưu tập này."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
                <div class="form-text">Không bắt buộc. Tối đa 500 ký tự.</div>
            </div>
        </section>

        <div class="form-actions">
            <a class="btn btn-outline-secondary" asp-action="Index">Hủy</a>
            <button type="submit" class="btn btn-primary">Tạo bộ sưu tập</button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
