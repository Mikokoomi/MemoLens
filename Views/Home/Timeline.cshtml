@{
    ViewData["Title"] = "Dòng thời gian";
}

<section class="placeholder-shell">
    <div class="placeholder-main">
        <p class="kicker">Dòng thời gian riêng tư</p>
        <h1>Kỷ niệm của bạn sẽ xuất hiện trong một dòng thời gian nhẹ nhàng.</h1>
        <p>
            Trang được bảo vệ này dành cho danh sách kỷ niệm. Sau này, nó sẽ hiển thị khoảnh khắc của
            tài khoản đang đăng nhập theo ngày, kèm cảm xúc, địa điểm và ảnh xem trước.
        </p>
    </div>

    <div class="placeholder-card">
        <div class="timeline-line"></div>
        <div class="timeline-item">
            <span>Ngày kỷ niệm</span>
            <strong>Tiêu đề và cảm xúc</strong>
        </div>
        <div class="timeline-item muted">
            <span>Địa điểm</span>
            <strong>Trích đoạn câu chuyện</strong>
        </div>
        <p class="placeholder-note">
            Trang giữ chỗ. CRUD kỷ niệm, upload ảnh và dữ liệu thật chưa được triển khai ở bước này.
        </p>
    </div>
</section>
