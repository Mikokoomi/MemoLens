@{
    ViewData["Title"] = "Trang chủ";
}

<section class="prototype-home">
    <div class="prototype-home-hero">
        <div class="prototype-hero-copy">
            <h1 class="prototype-hero-title">Lưu giữ những kỷ niệm của bạn</h1>
            <p>MemoLens giúp bạn lưu lại khoảnh khắc đáng nhớ trong một cuốn sổ ảnh riêng tư, ấm áp và chỉ thuộc về bạn.</p>
            <div class="prototype-hero-actions">
                <a class="btn btn-primary" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                <a class="btn btn-outline-secondary" asp-controller="Account" asp-action="Register">Tạo tài khoản</a>
            </div>
        </div>

        <div class="prototype-collage" aria-label="Ba tấm ảnh kỷ niệm trên trang giấy">
            <div class="prototype-note-sheet" aria-hidden="true"></div>
            <div class="prototype-polaroid prototype-polaroid-one prototype-tape"><span></span></div>
            <div class="prototype-polaroid prototype-polaroid-two prototype-tape"><span></span></div>
            <div class="prototype-polaroid prototype-polaroid-three prototype-tape"><span></span></div>
        </div>
    </div>

    <section class="prototype-feature-grid" aria-label="Điểm chính của MemoLens">
        <article class="prototype-feature-card prototype-tape">
            <span class="prototype-feature-icon" aria-hidden="true">◇</span>
            <div>
                <h2>Riêng tư</h2>
                <p>Kỷ niệm chỉ dành cho bạn xem lại.</p>
            </div>
        </article>
        <article class="prototype-feature-card prototype-tape">
            <span class="prototype-feature-icon" aria-hidden="true">♡</span>
            <div>
                <h2>Kỷ niệm</h2>
                <p>Ghi lại câu chuyện, ngày và cảm xúc.</p>
            </div>
        </article>
        <article class="prototype-feature-card prototype-tape">
            <span class="prototype-feature-icon" aria-hidden="true">▣</span>
            <div>
                <h2>Bộ sưu tập</h2>
                <p>Sắp xếp ảnh theo chủ đề yêu thích.</p>
            </div>
        </article>
    </section>
</section>
