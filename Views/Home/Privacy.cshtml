@{
    ViewData["Title"] = "Privacy";
}

<section class="content-panel content-panel-wide">
    <div class="content-intro">
        <p class="kicker">Privacy promise</p>
        <h1>Memories are private by default.</h1>
        <p>
            MemoLens is being built as a personal memory diary. The product direction is simple:
            a user should only see their own memories after signing in.
        </p>
    </div>

    <div class="row g-4 mt-2">
        <div class="col-md-6">
            <div class="quiet-box">
                <h2>What stays out</h2>
                <ul class="calm-list">
                    <li>No public feed.</li>
                    <li>No likes or comments.</li>
                    <li>No followers or public profiles.</li>
                    <li>No explore or trending page.</li>
                </ul>
            </div>
        </div>
        <div class="col-md-6">
            <div class="quiet-box">
                <h2>What is protected</h2>
                <ul class="calm-list">
                    <li>Login is required before viewing memories, albums, trash, settings, or private images.</li>
                    <li>Users can only manage their own memories and albums.</li>
                    <li>New images are stored outside wwwroot and served through an authorized endpoint.</li>
                    <li>Export and account deletion are planned for a future phase.</li>
                </ul>
            </div>
        </div>
    </div>
</section>
