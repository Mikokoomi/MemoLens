@model MemoLens.Models.Settings.EditProfileViewModel

@{
    ViewData["Title"] = "Sua ten hien thi";
}

<section class="settings-form-shell">
    <div class="memory-form-intro">
        <p class="kicker">Thong tin tai khoan</p>
        <h1>Sua ten hien thi.</h1>
        <p>Ten hien thi giup MemoLens goi khong gian rieng cua ban mem hon. Email khong duoc thay doi trong phase nay.</p>
    </div>

    <form asp-action="EditProfile" method="post" class="memory-form-panel settings-form-panel">
        <div asp-validation-summary="ModelOnly" class="text-danger validation-summary mb-3"></div>

        <div class="mb-4">
            <label asp-for="DisplayName" class="form-label">Ten hien thi</label>
            <input asp-for="DisplayName" class="form-control" autocomplete="name" />
            <span asp-validation-for="DisplayName" class="text-danger"></span>
            <div class="form-text">Co the de trong. Khi do MemoLens se hien email thay cho ten hien thi.</div>
        </div>

        <div class="memory-action-row">
            <button type="submit" class="btn btn-primary">Luu thay doi</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Huy</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
