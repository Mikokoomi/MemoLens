@model MemoLens.Models.Settings.SettingsIndexViewModel

@{
    ViewData["Title"] = "Cài đặt";
    var displayName = string.IsNullOrWhiteSpace(Model.DisplayName) ? Model.Email : Model.DisplayName;
}

<section class="settings-hero account-hero paper-note-panel">
    <div>
        <p class="kicker">Không gian tài khoản</p>
        <h1>Cài đặt</h1>
        <p>Quản lý tên hiển thị, mật khẩu và những ghi chú quyền riêng tư của không gian kỷ niệm cá nhân.</p>
    </div>
    <div class="settings-actions">
        <a class="btn btn-primary" asp-action="EditProfile">Sửa tên hiển thị</a>
        <a class="btn btn-outline-secondary" asp-action="ChangePassword">Đổi mật khẩu</a>
    </div>
</section>

@if (TempData["SettingsMessage"] is string message)
{
    <div class="settings-message" role="status">@message</div>
}

<section class="settings-grid settings-journal-grid">
    <article class="settings-card account-panel settings-card-primary">
        <p class="kicker">Thông tin tài khoản</p>
        <h2>@displayName</h2>
        <dl class="settings-facts account-facts">
            <div>
                <dt>Tên hiển thị</dt>
                <dd>@(string.IsNullOrWhiteSpace(Model.DisplayName) ? "Chưa đặt tên hiển thị" : Model.DisplayName)</dd>
            </div>
            <div>
                <dt>Email</dt>
                <dd>@Model.Email</dd>
            </div>
            <div>
                <dt>Trạng thái email</dt>
                <dd>
                    <span class="settings-status @(Model.EmailConfirmed ? "confirmed" : "unconfirmed")">
                        @(Model.EmailConfirmed ? "Đã xác thực" : "Chưa xác thực")
                    </span>
                </dd>
            </div>
            <div>
                <dt>Ngày tạo tài khoản</dt>
                <dd>@Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</dd>
            </div>
        </dl>
        <div class="settings-actions">
            <a class="btn btn-primary" asp-action="EditProfile">Sửa tên hiển thị</a>
            <a class="btn btn-outline-secondary" asp-action="ChangePassword">Đổi mật khẩu</a>
        </div>
    </article>

    <aside class="settings-card account-panel settings-privacy-card">
        <p class="kicker">Ghi chú quyền riêng tư</p>
        <h2>Kỷ niệm của bạn chỉ thuộc về bạn.</h2>
        <ul class="settings-note-list soft-list">
            <li>Kỷ niệm, bộ sưu tập, ảnh và thùng rác của bạn chỉ hiển thị với tài khoản của bạn.</li>
            <li>Ảnh được lưu ngoài <code>wwwroot</code> và chỉ được xem thông qua endpoint có kiểm tra đăng nhập và quyền sở hữu.</li>
            <li>MemoLens hiện chưa hỗ trợ chia sẻ công khai.</li>
            <li>Xuất dữ liệu và xóa tài khoản sẽ được bổ sung ở phase sau.</li>
        </ul>
    </aside>
</section>

<section class="settings-limits account-panel">
    <p class="kicker">Chưa có trong phase này</p>
    <div class="settings-limit-grid">
        <div>Chưa đổi email</div>
        <div>MVC và API đã có quên/đặt lại mật khẩu</div>
        <div>Chưa xuất dữ liệu</div>
        <div>Chưa xóa tài khoản</div>
    </div>
</section>
