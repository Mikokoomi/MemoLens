@model MemoLens.Models.Settings.ChangePasswordViewModel

@{
    ViewData["Title"] = "Doi mat khau";
}

<section class="settings-form-shell">
    <div class="memory-form-intro">
        <p class="kicker">Bao ve tai khoan</p>
        <h1>Doi mat khau.</h1>
        <p>Nhap mat khau hien tai truoc khi dat mat khau moi. Mat khau moi can it nhat 8 ky tu va co chu lan so.</p>
    </div>

    <form asp-action="ChangePassword" method="post" class="memory-form-panel settings-form-panel">
        <div asp-validation-summary="ModelOnly" class="text-danger validation-summary mb-3"></div>

        <div class="mb-3">
            <label asp-for="CurrentPassword" class="form-label">Mat khau hien tai</label>
            <input asp-for="CurrentPassword" class="form-control" autocomplete="current-password" />
            <span asp-validation-for="CurrentPassword" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="NewPassword" class="form-label">Mat khau moi</label>
            <input asp-for="NewPassword" class="form-control" autocomplete="new-password" />
            <span asp-validation-for="NewPassword" class="text-danger"></span>
            <div class="form-text">Toi thieu 8 ky tu, co it nhat mot chu va mot so.</div>
        </div>

        <div class="mb-4">
            <label asp-for="ConfirmPassword" class="form-label">Xac nhan mat khau moi</label>
            <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>

        <div class="memory-action-row">
            <button type="submit" class="btn btn-primary">Luu thay doi</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Huy</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
