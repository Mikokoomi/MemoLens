@model MemoLens.Models.Memories.MemoryIndexViewModel

@{
    ViewData["Title"] = "Dòng thời gian";
    var advancedFilterOpen = Model.Filter.HasAnyFilter &&
        (!string.IsNullOrWhiteSpace(Model.Filter.Feeling) || Model.Filter.TagId.HasValue ||
        Model.Filter.FromDate.HasValue || Model.Filter.ToDate.HasValue || Model.Filter.Month.HasValue ||
        Model.Filter.Year.HasValue || !string.Equals(Model.Filter.SortOrder, "newest", StringComparison.OrdinalIgnoreCase));
    var monthNames = new[] { "Tháng 1", "Tháng 2", "Tháng 3", "Tháng 4", "Tháng 5", "Tháng 6", "Tháng 7", "Tháng 8", "Tháng 9", "Tháng 10", "Tháng 11", "Tháng 12" };
}

<section class="prototype-timeline">
    <header class="prototype-page-header">
        <div>
            <h1 class="prototype-page-title">Những kỷ niệm của bạn</h1>
            <p class="prototype-subtitle">Lưu giữ những khoảnh khắc đáng nhớ.</p>
        </div>
        <a class="btn btn-primary prototype-create-button" asp-action="Create">+ Tạo kỷ niệm</a>
    </header>

    @if (!Model.HasMemories)
    {
        <section class="prototype-empty-state" aria-label="Chưa có kỷ niệm">
            <p>Chưa có kỷ niệm nào. Bắt đầu bằng một khoảnh khắc nhỏ.</p>
            <a class="btn btn-primary" asp-action="Create">Tạo kỷ niệm đầu tiên</a>
        </section>
    }
    else
    {
        <form asp-action="Index" method="get" class="prototype-search-area" aria-label="Tìm kiếm và bộ lọc">
            <div class="prototype-search-row">
                <label class="visually-hidden" for="search">Tìm kiếm kỷ niệm</label>
                <input id="search" name="search" class="form-control" value="@Model.Filter.Search" placeholder="Tìm kiếm kỷ niệm..." />
                <button class="btn btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#advancedMemoryFilters" aria-expanded="@(advancedFilterOpen.ToString().ToLowerInvariant())" aria-controls="advancedMemoryFilters">Bộ lọc</button>
            </div>

            @if (Model.ValidationMessages.Any())
            {
                <div class="prototype-filter-message" role="alert">
                    @foreach (var message in Model.ValidationMessages)
                    {
                        <p>@message</p>
                    }
                </div>
            }

            <div class="collapse prototype-filter-collapse @(advancedFilterOpen ? "show" : "")" id="advancedMemoryFilters">
                <div class="prototype-filter-grid">
                    <div>
                        <label for="feeling" class="form-label">Cảm xúc</label>
                        <select id="feeling" name="feeling" class="form-select">
                            <option value="">Tất cả cảm xúc</option>
                            @foreach (var feeling in Model.FeelingOptions)
                            {
                                <option value="@feeling" selected="@(Model.Filter.Feeling == feeling)">@feeling</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label for="tagId" class="form-label">Thẻ</label>
                        <select id="tagId" name="tagId" class="form-select">
                            <option value="">Tất cả thẻ</option>
                            @foreach (var tag in Model.AvailableTags)
                            {
                                <option value="@tag.Id" selected="@(Model.Filter.TagId == tag.Id)">@tag.Name</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label for="fromDate" class="form-label">Từ ngày</label>
                        <input id="fromDate" name="fromDate" class="form-control" type="date" value="@Model.Filter.FromDate?.ToString("yyyy-MM-dd")" />
                    </div>
                    <div>
                        <label for="toDate" class="form-label">Đến ngày</label>
                        <input id="toDate" name="toDate" class="form-control" type="date" value="@Model.Filter.ToDate?.ToString("yyyy-MM-dd")" />
                    </div>
                    <div>
                        <label for="month" class="form-label">Tháng</label>
                        <select id="month" name="month" class="form-select">
                            <option value="">Tất cả tháng</option>
                            @for (var month = 1; month <= 12; month++)
                            {
                                <option value="@month" selected="@(Model.Filter.Month == month)">@monthNames[month - 1]</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label for="year" class="form-label">Năm</label>
                        <select id="year" name="year" class="form-select">
                            <option value="">Tất cả năm</option>
                            @foreach (var year in Model.AvailableYears)
                            {
                                <option value="@year" selected="@(Model.Filter.Year == year)">@year</option>
                            }
                            @if (Model.Filter.Year.HasValue && !Model.AvailableYears.Contains(Model.Filter.Year.Value))
                            {
                                <option value="@Model.Filter.Year" selected="selected">@Model.Filter.Year</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label for="sortOrder" class="form-label">Sắp xếp</label>
                        <select id="sortOrder" name="sortOrder" class="form-select">
                            <option value="newest" selected="@(Model.Filter.SortOrder == "newest")">Mới nhất trước</option>
                            <option value="oldest" selected="@(Model.Filter.SortOrder == "oldest")">Cũ nhất trước</option>
                        </select>
                    </div>
                    <div class="prototype-filter-actions">
                        <button type="submit" class="btn btn-primary">Áp dụng</button>
                        <a class="btn btn-outline-secondary" asp-action="Index">Xóa bộ lọc</a>
                    </div>
                </div>
            </div>
            @if (Model.Filter.HasAnyFilter)
            {
                <a class="prototype-clear-filter" asp-action="Index">Xóa bộ lọc</a>
            }
        </form>

        @if (!Model.HasResults)
        {
            <section class="prototype-empty-state" aria-label="Không có kết quả">
                <p>Chưa tìm thấy kỷ niệm phù hợp với bộ lọc này.</p>
                <a class="btn btn-primary" asp-action="Index">Xóa bộ lọc</a>
            </section>
        }
        else
        {
            <section class="prototype-memory-grid" aria-label="Danh sách kỷ niệm">
                @foreach (var memory in Model.Memories)
                {
                    <article class="prototype-memory-card prototype-tape">
                        <a class="prototype-memory-cover" asp-action="Details" asp-route-id="@memory.Id" aria-label="Xem kỷ niệm @memory.Title">
                            @if (memory.CoverImageId.HasValue)
                            {
                                <img src="@Url.Action("MemoryImage", "Images", new { id = memory.CoverImageId })" alt="@memory.Title" onerror="this.hidden=true; this.parentElement.classList.add('is-missing');" />
                            }
                            else
                            {
                                <span class="prototype-no-image">Chưa có ảnh</span>
                            }
                        </a>
                        <h2><a asp-action="Details" asp-route-id="@memory.Id">@memory.Title</a></h2>
                        <div class="prototype-memory-meta">
                            <time datetime="@memory.MemoryDate.ToString("yyyy-MM-dd")">@memory.MemoryDate.ToString("dd/MM/yyyy")</time>
                            <span>@(!string.IsNullOrWhiteSpace(memory.Location) ? memory.Location : memory.Feeling)</span>
                        </div>
                        <div class="prototype-memory-extra">
                            <span>@memory.Feeling</span>
                            @if (memory.Tags.Any())
                            {
                                <span>@string.Join(" · ", memory.Tags)</span>
                            }
                        </div>
                    </article>
                }
            </section>
        }
    }
</section>
