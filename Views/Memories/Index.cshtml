@model MemoLens.Models.Memories.MemoryIndexViewModel

@{
    ViewData["Title"] = "Timeline";
    var advancedFilterOpen = Model.Filter.HasAnyFilter &&
        (!string.IsNullOrWhiteSpace(Model.Filter.Feeling) ||
        Model.Filter.TagId.HasValue ||
        Model.Filter.FromDate.HasValue ||
        Model.Filter.ToDate.HasValue ||
        Model.Filter.Month.HasValue ||
        Model.Filter.Year.HasValue ||
        !string.Equals(Model.Filter.SortOrder, "newest", StringComparison.OrdinalIgnoreCase));
    var monthNames = new[]
    {
        "Thang 1",
        "Thang 2",
        "Thang 3",
        "Thang 4",
        "Thang 5",
        "Thang 6",
        "Thang 7",
        "Thang 8",
        "Thang 9",
        "Thang 10",
        "Thang 11",
        "Thang 12"
    };
}

<section class="memory-page-header">
    <div>
        <p class="kicker">Private timeline</p>
        <h1>Your memory timeline</h1>
        <p>Only your confirmed account can see these memories, stories, and photos.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Create Memory</a>
</section>

@if (!Model.HasMemories)
{
    <section class="memory-empty-state">
        <p class="kicker">No memories yet</p>
        <h2>Start with one small moment.</h2>
        <p>
            Add a title, story, feeling, date, location, tags, and private photos.
            Keep it simple and personal.
        </p>
        <a class="btn btn-primary" asp-action="Create">Create your first memory</a>
    </section>
}
else
{
    <section class="memory-filter-panel">
        <div class="memory-filter-heading">
            <div>
                <p class="kicker">Tim lai ky uc</p>
                <h2>Tim kiem &amp; bo loc</h2>
            </div>
            <p>Tim nhanh truoc, mo bo loc nang cao khi ban can loc theo cam giac, the, ngay thang.</p>
        </div>

        @if (Model.ValidationMessages.Any())
        {
            <div class="memory-filter-alert" role="alert">
                @foreach (var message in Model.ValidationMessages)
                {
                    <p>@message</p>
                }
            </div>
        }

        @if (Model.Filter.HasAnyFilter)
        {
            <div class="active-filter-strip" aria-label="Current filters">
                <span>Dang loc timeline cua ban</span>
                @if (!string.IsNullOrWhiteSpace(Model.Filter.Search))
                {
                    <strong>Tu khoa: @Model.Filter.Search</strong>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Filter.Feeling))
                {
                    <strong>Cam giac: @Model.Filter.Feeling</strong>
                }
                @if (Model.Filter.TagId.HasValue)
                {
                    var selectedTag = Model.AvailableTags.FirstOrDefault(tag => tag.Id == Model.Filter.TagId.Value);
                    <strong>The: @(selectedTag?.Name ?? Model.Filter.TagId.Value.ToString())</strong>
                }
                @if (Model.Filter.FromDate.HasValue || Model.Filter.ToDate.HasValue)
                {
                    <strong>Khoang ngay</strong>
                }
                else if (Model.Filter.Year.HasValue)
                {
                    <strong>@(Model.Filter.Month.HasValue ? $"Thang {Model.Filter.Month}/{Model.Filter.Year}" : $"Nam {Model.Filter.Year}")</strong>
                }
            </div>
        }

        <form asp-action="Index" method="get" class="memory-filter-form">
            <div class="memory-filter-primary">
                <div class="filter-field">
                    <label for="search" class="form-label">Tim kiem</label>
                    <input id="search" name="search" class="form-control" value="@Model.Filter.Search" placeholder="Dalat, gia dinh, chuyen di..." />
                </div>
                <div class="memory-filter-primary-actions">
                    <button type="submit" class="btn btn-primary">Tim</button>
                    <button class="btn btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#advancedMemoryFilters" aria-expanded="@(advancedFilterOpen.ToString().ToLowerInvariant())" aria-controls="advancedMemoryFilters">
                        Bo loc
                    </button>
                    @if (Model.Filter.HasAnyFilter)
                    {
                        <a class="btn btn-link" asp-action="Index">Xoa</a>
                    }
                </div>
            </div>

            <div class="collapse memory-filter-collapse @(advancedFilterOpen ? "show" : "")" id="advancedMemoryFilters">
                <div class="memory-filter-grid">
                    <div class="filter-field">
                        <label for="feeling" class="form-label">Cam giac</label>
                        <select id="feeling" name="feeling" class="form-select">
                            <option value="">Tat ca cam giac</option>
                            @foreach (var feeling in Model.FeelingOptions)
                            {
                                <option value="@feeling" selected="@(Model.Filter.Feeling == feeling)">@feeling</option>
                            }
                        </select>
                    </div>

                    <div class="filter-field">
                        <label for="tagId" class="form-label">The</label>
                        <select id="tagId" name="tagId" class="form-select">
                            <option value="">Tat ca the</option>
                            @foreach (var tag in Model.AvailableTags)
                            {
                                <option value="@tag.Id" selected="@(Model.Filter.TagId == tag.Id)">@tag.Name</option>
                            }
                        </select>
                    </div>

                    <div class="filter-field">
                        <label for="fromDate" class="form-label">Tu ngay</label>
                        <input id="fromDate" name="fromDate" class="form-control" type="date" value="@Model.Filter.FromDate?.ToString("yyyy-MM-dd")" />
                    </div>

                    <div class="filter-field">
                        <label for="toDate" class="form-label">Den ngay</label>
                        <input id="toDate" name="toDate" class="form-control" type="date" value="@Model.Filter.ToDate?.ToString("yyyy-MM-dd")" />
                    </div>

                    <div class="filter-field">
                        <label for="month" class="form-label">Thang</label>
                        <select id="month" name="month" class="form-select">
                            <option value="">Tat ca thang</option>
                            @for (var month = 1; month <= 12; month++)
                            {
                                <option value="@month" selected="@(Model.Filter.Month == month)">@monthNames[month - 1]</option>
                            }
                        </select>
                        <div class="form-text">Chon nam neu muon loc theo thang.</div>
                    </div>

                    <div class="filter-field">
                        <label for="year" class="form-label">Nam</label>
                        <select id="year" name="year" class="form-select">
                            <option value="">Tat ca nam</option>
                            @foreach (var year in Model.AvailableYears)
                            {
                                <option value="@year" selected="@(Model.Filter.Year == year)">@year</option>
                            }
                            @if (Model.Filter.Year.HasValue && !Model.AvailableYears.Contains(Model.Filter.Year.Value))
                            {
                                <option value="@Model.Filter.Year" selected="selected">@Model.Filter.Year</option>
                            }
                        </select>
                    </div>

                    <div class="filter-field">
                        <label for="sortOrder" class="form-label">Sap xep</label>
                        <select id="sortOrder" name="sortOrder" class="form-select">
                            <option value="newest" selected="@(Model.Filter.SortOrder == "newest")">Moi nhat truoc</option>
                            <option value="oldest" selected="@(Model.Filter.SortOrder == "oldest")">Cu nhat truoc</option>
                        </select>
                    </div>

                    <div class="memory-filter-actions">
                        <button type="submit" class="btn btn-primary">Ap dung</button>
                        <a class="btn btn-outline-secondary" asp-action="Index">Xoa bo loc</a>
                    </div>
                </div>
            </div>
        </form>
    </section>

    @if (!Model.HasResults)
    {
        <section class="memory-empty-state memory-filter-empty">
            <p class="kicker">Khong co ket qua</p>
            <h2>Khong tim thay ky niem phu hop.</h2>
            <p>Thu doi bo loc hoac tim kiem bang tu khoa khac.</p>
            <a class="btn btn-primary" asp-action="Index">Xoa bo loc</a>
        </section>
    }
    else
    {
        <section class="memory-list">
            @foreach (var memory in Model.Memories)
            {
                <article class="memory-card">
                    @if (string.IsNullOrWhiteSpace(memory.CoverImagePath))
                    {
                        <div class="memory-card-photo-placeholder">
                            <span>No photo yet</span>
                        </div>
                    }
                    else
                    {
                        <a class="memory-card-cover" asp-action="Details" asp-route-id="@memory.Id">
                            <img src="@memory.CoverImagePath" alt="@memory.Title" />
                        </a>
                    }
                    <div class="memory-card-body">
                        <div class="memory-card-meta">
                            <span>@memory.MemoryDate.ToString("dd MMM yyyy")</span>
                            <span>@memory.Feeling</span>
                        </div>
                        <h2>
                            <a asp-action="Details" asp-route-id="@memory.Id">@memory.Title</a>
                        </h2>
                        @if (!string.IsNullOrWhiteSpace(memory.Location))
                        {
                            <p class="memory-location">@memory.Location</p>
                        }
                        <p class="memory-preview-text">
                            @(string.IsNullOrWhiteSpace(memory.Story)
                                ? "No story added yet."
                                : memory.Story.Length > 180 ? $"{memory.Story[..180]}..." : memory.Story)
                        </p>
                        @if (memory.Tags.Any())
                        {
                            <div class="tag-row">
                                @foreach (var tag in memory.Tags)
                                {
                                    <span>@tag</span>
                                }
                            </div>
                        }
                    </div>
                </article>
            }
        </section>
    }
}
