@model MemoLens.Models.Memories.MemoryFormViewModel

@{
    ViewData["Title"] = "Tạo kỷ niệm";
    var hasValidationErrors = ViewData.ModelState.Values.Any(entry => entry.Errors.Any());
}

<section class="prototype-memory-form-shell">
    <header class="prototype-page-header prototype-form-header">
        <div>
            <h1 class="prototype-page-title">Tạo kỷ niệm</h1>
            <p class="prototype-subtitle">Ghi lại khoảnh khắc, cảm xúc và câu chuyện của bạn.</p>
        </div>
    </header>

    <form asp-action="Create" method="post" enctype="multipart/form-data" class="prototype-memory-form prototype-tape">
        @if (hasValidationErrors)
        {
            <div asp-validation-summary="All" class="prototype-validation-summary" role="alert"></div>
        }

        <section class="prototype-form-section">
            <h2>Câu chuyện</h2>
            <div class="prototype-field">
                <label asp-for="Title"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="prototype-field">
                <label asp-for="Story"></label>
                <textarea asp-for="Story" class="form-control prototype-story-textarea" rows="7" placeholder="Hôm nay bạn muốn nhớ điều gì?"></textarea>
                <span asp-validation-for="Story" class="text-danger"></span>
                <small>Viết ngắn cũng được, miễn là đúng cảm xúc của bạn.</small>
            </div>
        </section>

        <section class="prototype-form-section">
            <div class="prototype-form-row">
                <div class="prototype-field">
                    <label asp-for="MemoryDate"></label>
                    <input asp-for="MemoryDate" class="form-control" type="date" />
                    <span asp-validation-for="MemoryDate" class="text-danger"></span>
                </div>
                <div class="prototype-field">
                    <label asp-for="Feeling"></label>
                    <select asp-for="Feeling" class="form-select">
                        <option value="">Chọn cảm xúc</option>
                        @foreach (var feeling in Model.FeelingOptions)
                        {
                            <option value="@feeling">@feeling</option>
                        }
                    </select>
                    <span asp-validation-for="Feeling" class="text-danger"></span>
                </div>
                <div class="prototype-field">
                    <label asp-for="Location"></label>
                    <input asp-for="Location" class="form-control" placeholder="Nhập địa điểm" />
                    <span asp-validation-for="Location" class="text-danger"></span>
                </div>
            </div>
        </section>

        <section class="prototype-form-section">
            <div class="prototype-field">
                <label asp-for="TagsText"></label>
                <input asp-for="TagsText" class="form-control" placeholder="Thêm thẻ (ví dụ: du lịch, bạn bè...)" />
                <span asp-validation-for="TagsText" class="text-danger"></span>
                <small>Ngăn cách các thẻ bằng dấu phẩy.</small>
            </div>
        </section>

        <section class="prototype-form-section">
            <h2>Ảnh</h2>
            <label class="prototype-upload-box" asp-for="NewImages">
                <span>
                    <strong>Thêm ảnh vào kỷ niệm</strong>
                    <small>Kéo thả hoặc chọn ảnh từ thiết bị</small>
                </span>
                <input asp-for="NewImages" class="form-control" type="file" multiple accept=".jpg,.jpeg,.png,.webp" />
            </label>
            <span asp-validation-for="NewImages" class="text-danger"></span>
            <small>Tối đa 10 ảnh, mỗi ảnh tối đa 5MB. Hỗ trợ JPG, PNG, WEBP.</small>
        </section>

        <div class="prototype-form-actions">
            <a class="btn btn-outline-secondary" asp-action="Index">Hủy</a>
            <button type="submit" class="btn btn-primary">Lưu kỷ niệm</button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
