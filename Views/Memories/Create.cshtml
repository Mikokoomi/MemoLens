@model MemoLens.Models.Memories.MemoryFormViewModel

@{
    ViewData["Title"] = "Tạo kỷ niệm";
}

<section class="memory-form-shell memory-writing-shell">
    <aside class="memory-form-intro paper-note-panel">
        <p class="kicker">Tạo kỷ niệm</p>
        <h1>Viết lại một khoảnh khắc theo cách riêng của bạn.</h1>
        <p>Thêm câu chuyện, cảm xúc, thời gian, địa điểm, thẻ và ảnh. Mọi thứ vẫn nằm trong không gian riêng tư của tài khoản này.</p>
        <div class="private-note">
            <strong>Riêng tư mặc định</strong>
            <span>Ảnh chỉ được phục vụ qua endpoint có kiểm tra quyền sở hữu.</span>
        </div>
    </aside>

    <form asp-action="Create" method="post" enctype="multipart/form-data" class="memory-form-card">
        <div asp-validation-summary="All" class="text-danger validation-summary form-validation-note mb-3"></div>

        <section class="form-section" aria-labelledby="story-section-heading">
            <div class="form-section-heading">
                <p class="kicker">Câu chuyện</p>
                <h2 id="story-section-heading">Điều bạn muốn nhớ</h2>
            </div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-0">
                <label asp-for="Story" class="form-label"></label>
                <textarea asp-for="Story" class="form-control journal-textarea" rows="8"></textarea>
                <span asp-validation-for="Story" class="text-danger"></span>
                <div class="form-text">Bạn có thể viết vài dòng ngắn hoặc một câu chuyện dài hơn cho kỷ niệm này.</div>
            </div>
        </section>

        <section class="form-section" aria-labelledby="time-section-heading">
            <div class="form-section-heading">
                <p class="kicker">Thời gian & cảm xúc</p>
                <h2 id="time-section-heading">Đặt kỷ niệm vào đúng ngữ cảnh</h2>
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Feeling" class="form-label"></label>
                    <select asp-for="Feeling" class="form-select">
                        <option value="">Chọn cảm xúc</option>
                        @foreach (var feeling in Model.FeelingOptions)
                        {
                            <option value="@feeling">@feeling</option>
                        }
                    </select>
                    <span asp-validation-for="Feeling" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="MemoryDate" class="form-label"></label>
                    <input asp-for="MemoryDate" class="form-control" type="date" />
                    <span asp-validation-for="MemoryDate" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-3">
                <label asp-for="Location" class="form-label"></label>
                <input asp-for="Location" class="form-control" />
                <span asp-validation-for="Location" class="text-danger"></span>
            </div>
        </section>

        <section class="form-section" aria-labelledby="tags-section-heading">
            <div class="form-section-heading">
                <p class="kicker">Thẻ</p>
                <h2 id="tags-section-heading">Gợi nhớ nhanh sau này</h2>
            </div>

            <label asp-for="TagsText" class="form-label"></label>
            <input asp-for="TagsText" class="form-control" placeholder="thực tập, gia đình, cà phê" />
            <span asp-validation-for="TagsText" class="text-danger"></span>
            <div class="form-text">Ngăn cách các thẻ bằng dấu phẩy.</div>
        </section>

        <section class="form-section upload-note" aria-labelledby="photos-section-heading">
            <div class="form-section-heading">
                <p class="kicker">Ảnh</p>
                <h2 id="photos-section-heading">Thêm những khung hình riêng tư</h2>
            </div>

            <label asp-for="NewImages" class="form-label"></label>
            <input asp-for="NewImages" class="form-control" type="file" multiple accept=".jpg,.jpeg,.png,.webp" />
            <span asp-validation-for="NewImages" class="text-danger"></span>
            <div class="form-text">Tối đa 10 ảnh, mỗi ảnh tối đa 5MB. Hỗ trợ JPG, PNG, WEBP.</div>
        </section>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Lưu kỷ niệm</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Hủy</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
