@model MemoLens.Models.Memories.MemoryDetailsViewModel

@{
    ViewData["Title"] = Model.Title;
    var hasStory = !string.IsNullOrWhiteSpace(Model.Story);
    var hasLocation = !string.IsNullOrWhiteSpace(Model.Location);
    var hasTags = Model.Tags.Any();
    var hasImages = Model.Images.Any();
}

<section class="prototype-memory-details">
    <a class="prototype-back-link" asp-action="Index">← Quay lại</a>

    <header class="prototype-detail-header">
        <h1 class="prototype-page-title">@Model.Title</h1>
        <div class="prototype-meta-chips" aria-label="Thông tin kỷ niệm">
            <span>@Model.MemoryDate.ToString("dd/MM/yyyy")</span>
            <span>@Model.Feeling</span>
            @if (hasLocation)
            {
                <span>@Model.Location</span>
            }
        </div>
    </header>

    @if (hasImages)
    {
        <section class="prototype-detail-gallery" aria-label="Ảnh kèm theo">
            @foreach (var image in Model.Images)
            {
                <figure class="prototype-detail-photo prototype-tape">
                    <img src="@Url.Action("MemoryImage", "Images", new { id = image.Id })"
                         alt="Ảnh trong kỷ niệm: @image.OriginalFileName"
                         onerror="this.hidden=true; this.closest('.prototype-detail-photo').classList.add('is-missing');" />
                    @if (!string.IsNullOrWhiteSpace(image.Caption))
                    {
                        <figcaption>@image.Caption</figcaption>
                    }
                </figure>
            }
        </section>
    }

    <article class="prototype-story-card">
        <h2>Câu chuyện</h2>
        <p>@(hasStory ? Model.Story : "Chưa có câu chuyện cho kỷ niệm này. Bạn có thể thêm vài dòng khi chỉnh sửa.")</p>

        @if (hasTags)
        {
            <div class="prototype-tag-row" aria-label="Thẻ của kỷ niệm">
                @foreach (var tag in Model.Tags)
                {
                    <span>@tag</span>
                }
            </div>
        }

        <p class="prototype-time-note">Tạo lúc @Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm") · Cập nhật @Model.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
    </article>

    @if (!hasImages)
    {
        <section class="prototype-gallery-empty" aria-label="Chưa có ảnh">
            <strong>Chưa có ảnh kèm theo</strong>
            <span>Thêm ảnh khi chỉnh sửa kỷ niệm này.</span>
        </section>
    }

    <nav class="prototype-detail-actions" aria-label="Hành động với kỷ niệm">
        <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.Id">Sửa</a>
        <a class="btn btn-outline-secondary" asp-action="Delete" asp-route-id="@Model.Id">Xóa</a>
        <a class="btn btn-primary" asp-action="Index">Quay lại</a>
    </nav>
</section>
