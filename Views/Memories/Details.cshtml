@model MemoLens.Models.Memories.MemoryDetailsViewModel

@{
    ViewData["Title"] = Model.Title;
}

<section class="memory-detail">
    <div class="memory-detail-main">
        <p class="kicker">Chi tiết kỷ niệm</p>
        <h1>@Model.Title</h1>

        <dl class="memory-facts">
            <div>
                <dt>Cảm xúc</dt>
                <dd>@Model.Feeling</dd>
            </div>
            <div>
                <dt>Ngày</dt>
                <dd>@Model.MemoryDate.ToString("dd/MM/yyyy")</dd>
            </div>
            <div>
                <dt>Địa điểm</dt>
                <dd>@(string.IsNullOrWhiteSpace(Model.Location) ? "Chưa thêm" : Model.Location)</dd>
            </div>
        </dl>

        <div class="story-panel">
            <h2>Câu chuyện / ghi chú</h2>
            <p>@(string.IsNullOrWhiteSpace(Model.Story) ? "Chưa có câu chuyện cho kỷ niệm này." : Model.Story)</p>
        </div>

        @if (Model.Tags.Any())
        {
            <div class="tag-row detail-tags">
                @foreach (var tag in Model.Tags)
                {
                    <span>@tag</span>
                }
            </div>
        }

        <p class="memory-time-note">
            Tạo lúc @Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm") &middot; Cập nhật @Model.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
        </p>
    </div>

    <aside class="memory-side-panel">
        <p class="kicker">Thư viện ảnh</p>
        @if (!Model.Images.Any())
        {
            <div class="memory-card-photo-placeholder large">
                <span>Chưa có ảnh nào trong kỷ niệm này.</span>
            </div>
        }
        else
        {
            <div class="memory-gallery">
                @foreach (var image in Model.Images)
                {
                    <figure>
                        <img src="@Url.Action("MemoryImage", "Images", new { id = image.Id })" alt="@image.OriginalFileName" onerror="this.hidden=true; this.parentElement.classList.add('image-missing');" />
                    </figure>
                }
            </div>
        }
        <div class="d-grid gap-2">
            <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Sửa kỷ niệm</a>
            <a class="btn btn-outline-secondary" asp-action="Delete" asp-route-id="@Model.Id">Xóa kỷ niệm</a>
            <a class="btn btn-link" asp-action="Index">Quay lại dòng thời gian</a>
        </div>
    </aside>
</section>
