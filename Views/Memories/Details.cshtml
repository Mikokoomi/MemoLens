@model MemoLens.Models.Memories.MemoryDetailsViewModel

@{
    ViewData["Title"] = Model.Title;
}

<section class="memory-detail">
    <div class="memory-detail-main">
        <p class="kicker">Memory detail</p>
        <h1>@Model.Title</h1>

        <dl class="memory-facts">
            <div>
                <dt>Feeling</dt>
                <dd>@Model.Feeling</dd>
            </div>
            <div>
                <dt>Date</dt>
                <dd>@Model.MemoryDate.ToString("dd MMM yyyy")</dd>
            </div>
            <div>
                <dt>Location</dt>
                <dd>@(string.IsNullOrWhiteSpace(Model.Location) ? "Not added" : Model.Location)</dd>
            </div>
        </dl>

        <div class="story-panel">
            <h2>Story / Note</h2>
            <p>@(string.IsNullOrWhiteSpace(Model.Story) ? "No story has been added yet." : Model.Story)</p>
        </div>

        @if (Model.Tags.Any())
        {
            <div class="tag-row detail-tags">
                @foreach (var tag in Model.Tags)
                {
                    <span>@tag</span>
                }
            </div>
        }

        <p class="memory-time-note">
            Created @Model.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm") · Updated @Model.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
        </p>
    </div>

    <aside class="memory-side-panel">
        <div class="memory-card-photo-placeholder large">
            <span>Photos will be added in Phase 5</span>
        </div>
        <div class="d-grid gap-2">
            <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit Memory</a>
            <a class="btn btn-outline-secondary" asp-action="Delete" asp-route-id="@Model.Id">Delete Memory</a>
            <a class="btn btn-link" asp-action="Index">Back to Timeline</a>
        </div>
    </aside>
</section>
