@model MemoLens.Models.Memories.MemoryFormViewModel

@{
    ViewData["Title"] = "Sửa kỷ niệm";
}

<section class="memory-form-shell memory-writing-shell edit-memory-shell paper-shell">
    <aside class="memory-form-intro paper-note-panel">
        <p class="kicker page-kicker">Sửa kỷ niệm</p>
        <h1 class="page-title">Chỉnh sửa kỷ niệm</h1>
        <p>Lưu giữ những khoảnh khắc đáng nhớ.</p>
        <div class="private-note">
            <strong>Không gian cá nhân</strong>
            <span>Thao tác này không tạo chia sẻ công khai và không thay đổi quyền truy cập ảnh.</span>
        </div>
    </aside>

    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="memory-form-card paper-card">
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="All" class="text-danger validation-summary form-validation-note mb-3"></div>

        <section class="form-section" aria-labelledby="story-section-heading">
            <div class="form-section-heading">
                <p class="kicker">Câu chuyện</p>
                <h2 id="story-section-heading">Nội dung kỷ niệm</h2>
            </div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-0">
                <label asp-for="Story" class="form-label"></label>
                <textarea asp-for="Story" class="form-control journal-textarea" rows="8"></textarea>
                <span asp-validation-for="Story" class="text-danger"></span>
                <div class="form-text">Giữ lại chi tiết quan trọng nhất để sau này đọc lại vẫn thấy đúng cảm xúc.</div>
            </div>
        </section>

        <section class="form-section" aria-labelledby="time-section-heading">
            <div class="form-section-heading">
                <p class="kicker">Ngày / Cảm xúc / Địa điểm</p>
                <h2 id="time-section-heading">Bối cảnh của kỷ niệm</h2>
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Feeling" class="form-label"></label>
                    <select asp-for="Feeling" class="form-select">
                        <option value="">Chọn cảm xúc</option>
                        @foreach (var feeling in Model.FeelingOptions)
                        {
                            <option value="@feeling">@feeling</option>
                        }
                    </select>
                    <span asp-validation-for="Feeling" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="MemoryDate" class="form-label"></label>
                    <input asp-for="MemoryDate" class="form-control" type="date" />
                    <span asp-validation-for="MemoryDate" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-3">
                <label asp-for="Location" class="form-label"></label>
                <input asp-for="Location" class="form-control" />
                <span asp-validation-for="Location" class="text-danger"></span>
            </div>
        </section>

        <section class="form-section" aria-labelledby="tags-section-heading">
            <div class="form-section-heading">
                <p class="kicker">Thẻ</p>
                <h2 id="tags-section-heading">Sắp xếp nhẹ nhàng</h2>
            </div>

            <label asp-for="TagsText" class="form-label"></label>
            <input asp-for="TagsText" class="form-control" placeholder="thực tập, gia đình, cà phê" />
            <span asp-validation-for="TagsText" class="text-danger"></span>
            <div class="form-text">Ngăn cách các thẻ bằng dấu phẩy.</div>
        </section>

        <section class="form-section upload-note" aria-labelledby="photos-section-heading">
            <div class="form-section-heading">
                <p class="kicker">Ảnh mới</p>
                <h2 id="photos-section-heading">Thêm ảnh khác</h2>
            </div>

            <label asp-for="NewImages" class="form-label"></label>
            <input asp-for="NewImages" class="form-control" type="file" multiple accept=".jpg,.jpeg,.png,.webp" />
            <span asp-validation-for="NewImages" class="text-danger"></span>
            <div class="form-text">Tối đa 10 ảnh, mỗi ảnh tối đa 5MB. Hỗ trợ JPG, PNG, WEBP.</div>
        </section>

        <div class="form-actions">
            <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Hủy</a>
            <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
        </div>
    </form>

    <aside class="paper-note-panel image-edit-panel">
        <div class="form-section-heading">
            <p class="kicker">Ảnh hiện có</p>
            <h2 class="memory-panel-title">Quản lý ảnh trong kỷ niệm</h2>
        </div>

        @if (!Model.ExistingImages.Any())
        {
            <div class="memory-gallery-empty">
                <span aria-hidden="true">+</span>
                <div>
                    <h3>Chưa có ảnh nào</h3>
                    <p>Bạn có thể thêm ảnh mới bằng vùng tải ảnh trong biểu mẫu bên trên.</p>
                </div>
            </div>
        }
        else
        {
            <div class="image-edit-grid">
                @foreach (var image in Model.ExistingImages)
                {
                    <article class="image-edit-card">
                        <div class="image-edit-frame">
                            <img src="@Url.Action("MemoryImage", "Images", new { id = image.Id })" alt="@image.OriginalFileName" onerror="this.hidden=true; this.parentElement.parentElement.classList.add('image-missing');" />
                        </div>
                        <form asp-action="DeleteImage" asp-route-id="@Model.Id" asp-route-imageId="@image.Id" method="post">
                            <button type="submit" class="btn btn-outline-danger image-delete-button">Xóa ảnh</button>
                        </form>
                    </article>
                }
            </div>
        }
    </aside>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
