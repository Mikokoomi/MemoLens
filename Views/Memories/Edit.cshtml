@model MemoLens.Models.Memories.MemoryFormViewModel

@{
    ViewData["Title"] = "Sửa kỷ niệm";
}

<section class="memory-form-shell">
    <div class="memory-form-intro">
        <p class="kicker">Sửa kỷ niệm</p>
        <h1>Chỉnh lại câu chuyện mà vẫn giữ nguyên quyền riêng tư.</h1>
        <p>Cập nhật nội dung, thêm ảnh mới hoặc xóa những ảnh không còn phù hợp.</p>
    </div>

    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="memory-form-panel">
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="All" class="text-danger validation-summary mb-3"></div>

        <div class="mb-3">
            <label asp-for="Title" class="form-label"></label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Story" class="form-label"></label>
            <textarea asp-for="Story" class="form-control" rows="7"></textarea>
            <span asp-validation-for="Story" class="text-danger"></span>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Feeling" class="form-label"></label>
                <select asp-for="Feeling" class="form-select">
                    <option value="">Chọn cảm xúc</option>
                    @foreach (var feeling in Model.FeelingOptions)
                    {
                        <option value="@feeling">@feeling</option>
                    }
                </select>
                <span asp-validation-for="Feeling" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="MemoryDate" class="form-label"></label>
                <input asp-for="MemoryDate" class="form-control" type="date" />
                <span asp-validation-for="MemoryDate" class="text-danger"></span>
            </div>
        </div>

        <div class="mb-3 mt-3">
            <label asp-for="Location" class="form-label"></label>
            <input asp-for="Location" class="form-control" />
            <span asp-validation-for="Location" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="TagsText" class="form-label"></label>
            <input asp-for="TagsText" class="form-control" placeholder="thực tập, gia đình, cà phê" />
            <span asp-validation-for="TagsText" class="text-danger"></span>
            <div class="form-text">Ngăn cách các thẻ bằng dấu phẩy.</div>
        </div>

        <div class="mb-4 memory-upload-box">
            <label asp-for="NewImages" class="form-label"></label>
            <input asp-for="NewImages" class="form-control" type="file" multiple accept=".jpg,.jpeg,.png,.webp" />
            <span asp-validation-for="NewImages" class="text-danger"></span>
            <div class="form-text">Tối đa 10 ảnh, mỗi ảnh tối đa 5MB. Hỗ trợ JPG, PNG, WEBP.</div>
        </div>

        <div class="memory-action-row">
            <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
            <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Hủy</a>
        </div>
    </form>

    <aside class="memory-form-panel">
        <p class="kicker">Ảnh</p>
        <h2 class="memory-panel-title">Ảnh hiện có</h2>
        @if (!Model.ExistingImages.Any())
        {
            <div class="memory-card-photo-placeholder large">
                <span>Chưa có ảnh nào được thêm.</span>
            </div>
        }
        else
        {
            <div class="edit-image-grid">
                @foreach (var image in Model.ExistingImages)
                {
                    <article class="edit-image-card">
                        <img src="@Url.Action("MemoryImage", "Images", new { id = image.Id })" alt="@image.OriginalFileName" onerror="this.hidden=true; this.parentElement.classList.add('image-missing');" />
                        <form asp-action="DeleteImage" asp-route-id="@Model.Id" asp-route-imageId="@image.Id" method="post">
                            <button type="submit" class="btn btn-outline-danger">Xóa ảnh</button>
                        </form>
                    </article>
                }
            </div>
        }
    </aside>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
